# =============================================================================
# The Smile Factory - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to git -- it contains secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase  (REQUIRED)
# Find these in your Supabase dashboard: Settings > API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# Staff Portal Access  (REQUIRED)
# Single shared key the team enters at /admin/login. Anyone who passes the
# key + signs in / creates an account is stored as 'employee'.
# Owner access is granted manually in Supabase by setting profiles.role to
# 'owner' for that user. (See /admin/settings → "Staff access & roles".)
# Multiple keys allowed (comma-separated) for rotation.
# Legacy variable name ADMIN_ACCESS_KEY is still read as a fallback.
# ---------------------------------------------------------------------------
STAFF_ACCESS_KEY=smile2024

# ---------------------------------------------------------------------------
# Resend - Email Service  (REQUIRED for email features)
# Sign up at https://resend.com and get your API key.
# RESEND_FROM_EMAIL should be a verified sender on your Resend account.
# If using a custom domain, verify it in Resend first (e.g. noreply@yourdomain.com).
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@thesmilefactoryarcade.com

# ---------------------------------------------------------------------------
# Google Places (OPTIONAL — used by /api/reviews/sync-google cron)
# Places API key with Place Details enabled + your business place_id
# ---------------------------------------------------------------------------
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACE_ID_SMILE_FACTORY=

# ---------------------------------------------------------------------------
# Cron auth (OPTIONAL — verify Vercel Cron calls in production)
# Set the same value in Vercel and send: Authorization: Bearer <CRON_SECRET>
# ---------------------------------------------------------------------------
# CRON_SECRET=
