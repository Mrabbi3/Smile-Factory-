# =============================================================================
# The Smile Factory - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to git -- it contains secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase  (REQUIRED)
# Find these in your Supabase dashboard: Settings > API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# Staff Portal Access  (REQUIRED)
# Comma-separated PIN codes that unlock /admin routes.
# Each staff member can have their own code, or share one.
# Example: smile2024,backroom99,owner123
# ---------------------------------------------------------------------------
ADMIN_ACCESS_KEY=your-staff-pin

# ---------------------------------------------------------------------------
# Resend - Email Service  (REQUIRED for email features)
# Sign up at https://resend.com and get your API key.
# RESEND_FROM_EMAIL should be a verified sender on your Resend account.
# If using a custom domain, verify it in Resend first (e.g. noreply@yourdomain.com).
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@thesmilefactoryarcade.com

# ---------------------------------------------------------------------------
# OpenAI - AI Chatbot & Analytics  (OPTIONAL)
# If not set, the AI chat gracefully falls back to a static message.
# Sign up at https://platform.openai.com and create an API key.
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-api-key
