NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
OPENAI_API_KEY=your-openai-api-key

# Owner-only key for staff/admin login. Only users who know this key can reach the admin sign-in.
# Generate a long random string and share only with the owner.
# Example: openssl rand -base64 32
ADMIN_ACCESS_KEY=your-secret-admin-key

# Resend — transactional email service (https://resend.com)
# 1. Create a free account at resend.com
# 2. Add & verify your domain, OR use onboarding@resend.dev for testing
# 3. Copy your API key from the dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@thesmilefactoryarcade.com